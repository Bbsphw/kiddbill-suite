{
	"packageManager": "pnpm@10.34.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@clerk/shared",
			"sharp",
			"unrs-resolver",
			"@prisma/engines",
			"prisma",
			"@nestjs/core"
		]
	},
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "turbo run format",
		"db:migrate:dev": "pnpm --filter server exec prisma migrate dev",
		"db:migrate:deploy": "pnpm --filter server exec prisma migrate deploy",
		"db:generate": "pnpm --filter server exec prisma generate",
		"db:studio": "pnpm --filter server exec prisma studio"
	},
	"dependencies": {
		"@prisma/adapter-pg": "7.3.0",
		"multer": "2.0.2",
		"pg": "8.18.0"
	},
	"devDependencies": {
		"@types/multer": "2.0.0",
		"@types/pg": "8.16.0",
		"turbo": "^2.9.17"
	}
}
