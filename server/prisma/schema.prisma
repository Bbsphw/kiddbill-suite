generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String            @id
  email        String?           @unique
  username     String?           @unique
  firstName    String?
  lastName     String?
  avatarUrl    String?
  isGuest      Boolean           @default(false)
  lastActiveAt DateTime          @default(now())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  ownedBills   Bill[]            @relation("Owner")
  paidBills    Bill[]            @relation("Payer")
  memberships  BillMember[]
  savedFriends Friend[]
  bankAccounts UserBankAccount[]
}

model Friend {
  id        String   @id @default(uuid())
  nickname  String
  userId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, nickname])
}

model UserBankAccount {
  id            String   @id @default(uuid())
  bankName      String
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, accountNumber])
}

model Bill {
  id                      String       @id @default(uuid())
  title                   String       @default("New Bill")
  note                    String?
  currency                String       @default("THB")
  receiptUrl              String?
  rawOcrData              Json?
  joinCode                String       @unique
  passcode                String?
  vatRate                 Decimal      @default(7.00) @db.Decimal(5, 2)
  serviceChargeRate       Decimal      @default(10.00) @db.Decimal(5, 2)
  isVatIncluded           Boolean      @default(true)
  isServiceChargeIncluded Boolean      @default(false)
  discountAmount          Decimal      @default(0) @db.Decimal(10, 2)
  discountPercent         Decimal      @default(0) @db.Decimal(5, 2)
  roundingMode            RoundingMode @default(NONE)
  promptPayNumber         String?
  promptPayName           String?
  bankName                String?
  bankAccount             String?
  status                  BillStatus   @default(DRAFT)
  deletedAt               DateTime?
  ownerId                 String
  payerId                 String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  owner                   User         @relation("Owner", fields: [ownerId], references: [id])
  payer                   User?        @relation("Payer", fields: [payerId], references: [id])
  items                   BillItem[]
  members                 BillMember[]

  @@index([ownerId])
  @@index([joinCode])
}

model BillItem {
  id                 String      @id @default(uuid())
  orderIndex         Int         @default(0)
  name               String
  price              Decimal     @db.Decimal(10, 2)
  quantity           Int         @default(1)
  totalPrice         Decimal     @default(0) @db.Decimal(10, 2)
  type               ItemType    @default(FOOD)
  applyVat           Boolean     @default(true)
  applyServiceCharge Boolean     @default(true)
  billId             String
  bill               Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  splits             ItemSplit[]

  @@index([billId])
}

model BillMember {
  id              String      @id @default(uuid())
  name            String
  isPaid          Boolean     @default(false)
  paidAt          DateTime?
  paymentProofUrl String?
  verifiedAt      DateTime?
  netAmountToPay  Decimal     @default(0) @db.Decimal(10, 2)
  paidAmount      Decimal     @default(0) @db.Decimal(10, 2)
  userId          String?
  billId          String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  bill            Bill        @relation(fields: [billId], references: [id], onDelete: Cascade)
  user            User?       @relation(fields: [userId], references: [id])
  splits          ItemSplit[]

  @@unique([billId, userId])
}

model ItemSplit {
  id          String     @id @default(uuid())
  itemId      String
  memberId    String
  weight      Decimal    @default(1.00) @db.Decimal(5, 2)
  fixedAmount Decimal?   @db.Decimal(10, 2)
  item        BillItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  member      BillMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([itemId, memberId])
  @@index([itemId])
}

enum BillStatus {
  DRAFT
  OCR_PROCESSING
  SPLITTING
  COMPLETED
  CANCELLED
}

enum RoundingMode {
  NONE
  UP
  DOWN
  NEAREST
}

enum ItemType {
  FOOD
  BEVERAGE
  ALCOHOL
  DISCOUNT
  OTHER
}
